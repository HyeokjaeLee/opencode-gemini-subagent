{
  "name": "opencode-gemini-subagent",
  "version": "0.2.0",
  "description": "Delegate work to Gemini as an opencode subagent — built-in web search, background tasks, preset automation.",
  "type": "module",
  "main": "dist/plugin.js",
  "files": [
    "dist",
    "agents"
  ],
  "scripts": {
    "build": "tsc && bun run build:bundle",
    "prepublishOnly": "tsc",
    "build:bundle": "bun build src/plugin.ts --outdir dist --target bun --external @opencode-ai/plugin --external @opencode-ai/sdk --external zod"
  },
  "keywords": [
    "opencode",
    "plugin",
    "gemini",
    "subagent",
    "ai",
    "llm"
  ],
  "author": "HyeokjaeLee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HyeokjaeLee/opencode-gemini-subagent.git"
  },
  "dependencies": {
    "yaml": "^2.7.1",
    "@opencode-ai/plugin": "^1.14.28",
    "@opencode-ai/sdk": ">=1.3.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.3.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "bugs": {
    "url": "https://github.com/HyeokjaeLee/opencode-gemini-subagent/issues"
  },
  "homepage": "https://github.com/HyeokjaeLee/opencode-gemini-subagent#readme",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./server": {
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    }
  }
}
